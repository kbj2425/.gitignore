        document.getElementById('soulStoneModal').style.display = 'none';
        soulStoneTargetId = null;
    }

    // 도감 조회
    let currentCollectionData = [];

    async function viewUserCollection(userId, username) {
        try {
            const res = await fetch(`/admin/collection/${userId}`);
            const data = await res.json();

            if (!data.success) {
                alert('도감을 불러올 수 없습니다.');
                return;
            }

            currentCollectionData = data.collection;
            document.getElementById('collectionModalTitle').textContent =
                `${username}의 도감`;
            renderCollectionGrid('all');
            document.getElementById('collectionModal').style.display = 'block';
        } catch (err) {
            alert('서버 오류가 발생했습니다.');
        }
    }

    function filterCollection(grade) {
        renderCollectionGrid(grade);
    }

    function renderCollectionGrid(filter) {
        const grid = document.getElementById('collectionGrid');
        const filtered = filter === 'all'
            ? currentCollectionData
            : currentCollectionData.filter(c => c.grade === filter);

        const gradeColors = {
            SSS: '#DAA520', SS: '#9B59B6', S: '#3498DB',
            A: '#27AE60', B: '#95A5A6', C: '#7f8c8d'
        };

        grid.innerHTML = filtered.map(char => {
            const color = gradeColors[char.grade];
            const opacity = char.owned ? '1' : '0.3';
            return `
                <div style="
                    background: white;
                    border-radius: 10px;
                    padding: 10px 6px;
                    text-align: center;
                    border: 2px solid ${char.owned ? color : '#ddd'};
                    opacity: ${opacity};
                ">
                    <img
                        src="/images/characters/${char.id}.png"
                        alt="${char.name}"
                        style="
                            width: 55px; height: 55px;
                            border-radius: 50%;
                            object-fit: cover;
                            border: 2px solid ${color};
                            ${!char.owned ? 'filter: brightness(0) opacity(0.3);' : ''}
                        "
                        onerror="this.style.display='none'; this.nextElementSibling.style.display='block';"
                    >
                    <div style="display:none; font-size:1.8em; line-height:55px;">❓</div>
                    <div style="
                        font-size: 0.65em;
                        font-weight: bold;
                        color: white;
                        background: ${color};
                        border-radius: 6px;
                        padding: 1px 5px;
                        display: inline-block;
                        margin: 4px 0;
                    ">${char.grade}</div>
                    <div style="font-size: 0.72em; color: #333; font-weight: bold;">
                        ${char.name}
                    </div>
                    ${char.owned && char.count > 1 ? `<div style="font-size:0.65em; color:#FF69B4;">×${char.count}</div>` : ''}
                </div>
            `;
        }).join('');
    }

    function closeCollectionModal() {
        document.getElementById('collectionModal').style.display = 'none';
        currentCollectionData = [];
    }

    // 캐릭터별 보유자 검색
    async function searchCharOwners() {
        const input = document.getElementById('charSearchInput').value.trim();
        const resultDiv = document.getElementById('charSearchResult');

        if (!input) {
            resultDiv.innerHTML = '<p style="color:#dc3545;">캐릭터 이름을 입력해주세요.</p>';
            return;
        }

        try {
            // 캐릭터 이름으로 ID 찾기 (프론트에서 매핑)
            const allChars = [
                {id:'sss_1',name:'황룡'},{id:'ss_1',name:'해태'},{id:'ss_2',name:'피닉스'},
                {id:'ss_3',name:'백호'},{id:'s_1',name:'구미호'},{id:'s_2',name:'그리핀'},
                {id:'s_3',name:'유니콘'},{id:'s_4',name:'현무'},{id:'s_5',name:'켈베로스'},
                {id:'a_1',name:'전투 코끼리'},{id:'a_2',name:'그림자 표범'},
                {id:'a_3',name:'왕관 독수리'},{id:'a_4',name:'화염 갈기 사자'},
                {id:'a_5',name:'서리 늑대'},{id:'a_6',name:'강철 뿔 코뿔소'},
                {id:'a_7',name:'환상 나비'},{id:'b_1',name:'불곰'},
                {id:'b_2',name:'사막 여우'},{id:'b_3',name:'정찰매'},
                {id:'b_4',name:'숲속 사슴'},{id:'b_5',name:'훈련된 군견'},
                {id:'b_6',name:'멧돼지 돌격병'},{id:'b_7',name:'약초 캐는 너구리'},
                {id:'b_8',name:'바다 거북'},{id:'b_9',name:'전기 뱀장어'},
                {id:'b_10',name:'산악 염소'},{id:'c_1',name:'들쥐'},
                {id:'c_2',name:'박쥐'},{id:'c_3',name:'길고양이'},
                {id:'c_4',name:'시골 강아지'},{id:'c_5',name:'파랑새'},
                {id:'c_6',name:'아기 토끼'},{id:'c_7',name:'두더지'},
                {id:'c_8',name:'떠돌이 개'},{id:'c_9',name:'고슴도치'},
                {id:'c_10',name:'다람쥐'},{id:'c_11',name:'개구리'},
                {id:'c_12',name:'까마귀'},{id:'c_13',name:'올챙이'},
                {id:'c_14',name:'병아리'}
            ];

            const matched = allChars.find(c =>
                c.name.includes(input) || input.includes(c.name)
            );

            if (!matched) {
                resultDiv.innerHTML = `<p style="color:#dc3545;">「${input}」 캐릭터를 찾을 수 없습니다.</p>`;
                return;
            }

            const res = await fetch(`/admin/collection/search/${matched.id}`);
            const data = await res.json();

            if (!data.success) {
                resultDiv.innerHTML = '<p style="color:#dc3545;">검색에 실패했습니다.</p>';
                return;
            }

            if (data.owners.length === 0) {
                resultDiv.innerHTML = `
                    <p style="color:#666;">
                        「${data.character.name}」을(를) 보유한 참가자가 없습니다.
                    </p>`;
                return;
            }

            resultDiv.innerHTML = `
                <p style="margin-bottom: 10px; color: #333;">
                    <strong>「${data.character.name}」</strong> 보유자
                    (${data.ownerCount}명)
                </p>
                <table class="users-table" style="margin-top: 0;">
                    <thead>
                        <tr>
                            <th>이름</th>
                            <th>보유 수</th>
                            <th>첫 획득일</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${data.owners.map(o => `
                            <tr>
                                <td>${o.username}</td>
                                <td>${o.count}</td>
                                <td>${new Date(o.first_obtained_at).toLocaleDateString('ko-KR')}</td>
                            </tr>
                        `).join('')}
                    </tbody>
                </table>
            `;
        } catch (err) {
            resultDiv.innerHTML = '<p style="color:#dc3545;">서버 오류가 발생했습니다.</p>';
        }
    }

    // Close modals when clicking outside
window.onclick = function(event) {
    const passwordModal = document.getElementById('passwordModal');
    const deleteModal = document.getElementById('deleteModal');
    const userRecordsModal = document.getElementById('userRecordsModal');
    const allUserRecordsModal = document.getElementById('allUserRecordsModal');
    const soulStoneModal = document.getElementById('soulStoneModal');
    const collectionModal = document.getElementById('collectionModal');

    if (event.target === passwordModal)      passwordModal.style.display = 'none';
    if (event.target === deleteModal)        deleteModal.style.display = 'none';
    if (event.target === soulStoneModal)     closeSoulStoneModal();
    if (event.target === collectionModal)    closeCollectionModal();
    if (event.target === userRecordsModal)   closeUserRecordsModal();
    if (event.target === allUserRecordsModal) closeAllUserRecordsModal();
}
    // 랭킹 조회
    async function loadRanking() {
        const year = document.getElementById('rankingYear').value;
        const month = document.getElementById('rankingMonth').value;
        
        try {
            const response = await fetch(`/admin/full-ranking?year=${year}&month=${month}`);
            const result = await response.json();
            
            if (result.success && result.rankings.length > 0) {
                displayRanking(result.rankings, year, month);
            } else {
                document.getElementById('rankingDisplay').innerHTML = 
                    `<p style="text-align: center; color: #666;">${year}년 ${month}월에는 훈련 기록이 없습니다.</p>`;
            }
        } catch (error) {
            console.error('랭킹 조회 오류:', error);
            alert('랭킹 조회에 실패했습니다.');
        }
    }

    function displayRanking(rankings, year, month) {
        const html = `
            <h3 style="margin-bottom: 15px;">${year}년 ${month}월 전체 랭킹 (총 ${rankings.length}명)</h3>
            <table class="ranking-table">
                <thead>
                    <tr>
                        <th>순위</th>
                        <th>이름</th>
                        <th>총점</th>
                        <th>정답률</th>
                        <th>완벽</th>
                        <th>근사</th>
                        <th>오답</th>
                        <th>시도</th>
                        <th>배지</th>
                    </tr>
                </thead>
                <tbody>
                    ${rankings.map((rank, index) => `
                        <tr class="ranking-row-${Math.min(index + 1, 6)}">
                            <td>
                                ${index === 0 ? '🥇' : index === 1 ? '🥈' : index === 2 ? '🥉' : index < 5 ? '🎖️' : ''}
                                ${index + 1}위
                            </td>
                            <td><strong>${rank.username}</strong></td>
                            <td><strong style="color: #FFC0CB;">${rank.total_score}점</strong></td>
                            <td>${rank.accuracy}%</td>
                            <td>${rank.perfect_count}</td>
                            <td>${rank.close_count}</td>
                            <td>${rank.wrong_count}</td>
                            <td>${rank.total_attempts}</td>
                            <td>
                                ${index === 0 ? '🥇 골드' : index === 1 ? '🥈 실버' : index === 2 ? '🥉 브론즈' : index < 5 ? '🎖️ 우수' : '-'}
                            </td>
                        </tr>
                    `).join('')}
                </tbody>
            </table>
        `;
        
        document.getElementById('rankingDisplay').innerHTML = html;
    }

    // 배지 수여
    async function awardBadges() {
        const year = document.getElementById('rankingYear').value;
        const month = document.getElementById('rankingMonth').value;
        
        if (!confirm(`${year}년 ${month}월 상위 5명에게 배지를 수여하시겠습니까?`)) {
            return;
        }
        
        try {
            const response = await fetch('/admin/award-badges', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ year: parseInt(year), month: parseInt(month) })
            });
            
            const result = await response.json();
            
            if (result.success) {
                alert('배지가 성공적으로 수여되었습니다!');
                loadRanking(); // 다시 로드
            } else {
                alert(result.message || '배지 수여에 실패했습니다.');
            }
        } catch (error) {
            console.error('배지 수여 오류:', error);
            alert('서버와의 통신에 실패했습니다.');
        }
    }

    // Close dropdown when clicking outside
    document.addEventListener('click', function(event) {
        const userMenu = document.querySelector('.user-menu');
        if (!userMenu.contains(event.target)) {
            document.getElementById('dropdown').classList.remove('show');
        }
    });
</script>
</body>
</html>
