        if (!amount || amount <= 0) {
            alert('유효한 수량을 입력해주세요.');
            return;
        }

        try {
            const res = await fetch('/admin/give-token', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ userId: soulStoneTargetId, amount })
            });
            const data = await res.json();

            if (data.success) {
                alert(`${data.message}\n현재 잔액: ${data.newBalance}개`);
                closeSoulStoneModal();
            } else {
                alert(data.message || '지급에 실패했습니다.');
            }
        } catch (err) {
            alert('서버 오류가 발생했습니다.');
        }
